# ===== App =====
APP_PORT=3000
LOG_LEVEL=info

# ===== Database =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_core

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== LLM (OpenAI 兼容，必须支持 function calling) =====
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL_ID=qwen-plus

# ===== Embedding =====
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL_ID=text-embedding-v3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=10

# ===== Reranker =====
RERANK_API_URL=https://llm-4ptv8s8giohyawe8.cn-beijing.maas.aliyuncs.com/compatible-api/v1/reranks
RERANK_API_KEY=your_api_key_here
RERANK_MODEL_ID=qwen3-rerank

# ===== Chunking =====
CHUNK_PARENT_TOKENS=1200
CHUNK_CHILD_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

# ===== Retrieval =====
SEARCH_TOP_K=10
DENSE_TOP_K_MULTIPLIER=3
RRF_K=60
RERANK_TOP_K=20
DENSE_MIN_SIMILARITY=0.35
RERANK_MIN_SCORE=0.5

# ===== Agent =====
AGENT_MAX_ITERATIONS=5
AGENT_MAX_TOOL_CALLS=10

# ===== Cache =====
EMBEDDING_CACHE_MAX=2000
RESULT_CACHE_MAX=500
RESULT_CACHE_TTL_MS=60000

# ===== Auth (JWT) =====
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_ACCESS_TTL_SEC=900  # 15 minutes
JWT_REFRESH_TTL_SEC=604800 # 7 days
QUERY_JOB_TTL_SEC=3600 # 1 hour
# 超级管理员初始账号（仅首次启动时创建）
AUTH_DEFAULT_USERNAME=admin
AUTH_DEFAULT_PASSWORD=

# 服务端永久 Token（脚本/集成调用，不在 Web 界面配置）
# API_SERVICE_TOKEN=your-long-random-service-token-here

# ===== Aliyun OSS  =====
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# OSS_BUCKET_NAME=kim-1001
# OSS_PREFIX=knowledge_core/