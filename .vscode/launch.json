{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Server (index.ts)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--inspect-wait", "src/index.ts"],
      "cwd": "${workspaceFolder}/app",
      "envFile": "${workspaceFolder}/app/.env",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Worker (queue.ts)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--inspect-wait", "src/pipeline/queue.ts"],
      "cwd": "${workspaceFolder}/app",
      "envFile": "${workspaceFolder}/app/.env",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current File",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--inspect-wait", "${file}"],
      "cwd": "${workspaceFolder}/app",
      "envFile": "${workspaceFolder}/app/.env",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current Test",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--inspect-wait", "test", "${relativeFile}"],
      "cwd": "${workspaceFolder}/app",
      "envFile": "${workspaceFolder}/app/.env",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Smoke Test",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--inspect-wait", "tests/smoke.ts"],
      "cwd": "${workspaceFolder}/app",
      "envFile": "${workspaceFolder}/app/.env",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Bun (port 6499)",
      "port": 6499,
      "restart": true,
      "localRoot": "${workspaceFolder}/app",
      "remoteRoot": "${workspaceFolder}/app"
    }
  ],
  "compounds": [
    {
      "name": "Server + Attach (manual)",
      "configurations": ["Attach to Bun (port 6499)"],
      "presentation": {
        "hidden": true
      }
    }
  ]
}
