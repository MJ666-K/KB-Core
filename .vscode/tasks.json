{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker: up",
      "type": "shell",
      "command": "docker compose up -d",
      "options": { "cwd": "${workspaceFolder}/app" },
      "problemMatcher": []
    },
    {
      "label": "db: migrate",
      "type": "shell",
      "command": "bun run db:migrate",
      "options": { "cwd": "${workspaceFolder}/app" },
      "problemMatcher": []
    },
    {
      "label": "dev: server",
      "type": "shell",
      "command": "bun run dev",
      "options": { "cwd": "${workspaceFolder}/app" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "test: all",
      "type": "shell",
      "command": "bun test",
      "options": { "cwd": "${workspaceFolder}/app" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "test: smoke",
      "type": "shell",
      "command": "bun tests/smoke.ts",
      "options": { "cwd": "${workspaceFolder}/app" },
      "problemMatcher": []
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "bun run typecheck",
      "options": { "cwd": "${workspaceFolder}/app" },
      "problemMatcher": ["$tsc"]
    }
  ]
}
