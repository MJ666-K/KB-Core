# ===== 部署端口（宿主机映射） =====
APP_PORT=3000

# ===== 应用镜像（先 ./build.sh 构建，再 deploy） =====
KC_IMAGE=kb-core:latest

# ===== PostgreSQL（docker-compose 内部使用） =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_core

# 本地开发直连时使用；Docker 部署时 compose 会覆盖为容器内地址
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_core
REDIS_URL=redis://localhost:6379/0

# ===== App =====
LOG_LEVEL=info

# ===== LLM（OpenAI 兼容，必须支持 function calling） =====
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL_ID=qwen-plus

# ===== Embedding =====
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL_ID=text-embedding-v3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=10

# ===== Reranker =====
RERANK_API_URL=https://your-rerank-endpoint/v1/reranks
RERANK_API_KEY=your_api_key_here
RERANK_MODEL_ID=qwen3-rerank

# ===== Chunking =====
CHUNK_PARENT_TOKENS=1200
CHUNK_CHILD_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

# ===== Retrieval =====
SEARCH_TOP_K=10
DENSE_TOP_K_MULTIPLIER=3
RRF_K=60
RERANK_TOP_K=20
DENSE_MIN_SIMILARITY=0.35
RERANK_MIN_SCORE=0.5

# ===== Agent =====
AGENT_MAX_ITERATIONS=5
AGENT_MAX_TOOL_CALLS=10

# ===== Cache =====
EMBEDDING_CACHE_MAX=2000
RESULT_CACHE_MAX=500
RESULT_CACHE_TTL_MS=60000

# ===== Auth =====
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
QUERY_JOB_TTL_SEC=3600
AUTH_DEFAULT_USERNAME=admin
AUTH_DEFAULT_PASSWORD=admin123

# 服务端永久 Token（脚本/集成，可选）
# API_SERVICE_TOKEN=your-long-random-service-token-here

# ===== Aliyun OSS（文档存储，四项都填则启用 OSS，否则存本地 ./documents） =====
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# OSS_BUCKET_NAME=your-bucket
# OSS_PREFIX=knowledge_core/

# ===== Neo4j（知识图谱） =====
# Docker 部署时 compose 会覆盖为 bolt://neo4j:7687；本地直连 Neo4j 用 localhost
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
# 小内存机器可改为 256m / 128m
NEO4J_HEAP_INITIAL=256m
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=256m
# 是否启用知识图谱（false 时 kg_* Tool 全部禁用）
KG_ENABLED=true
# 默认根节点（按 category 路由）
KG_DEFAULT_ROOT_LABOR=flow_labor_apply
KG_DEFAULT_ROOT_NEIGHBOR=flow_neighbor_register